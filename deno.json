{
  "name": "@cfs/utilities",
  "version": "0.0.0",
  "license": "MIT",
  "description": "Shared date and order utility functions for CFS applications.",
  "exports": {
    "./bookings": "./src/bookings.ts",
    "./contact-name": "./src/contact-name.ts",
    "./dates": "./src/dates.ts",
    "./invoices": "./src/invoices.ts",
    "./orders": "./src/orders.ts",
    "./products": "./src/products.ts"
  },
  "tasks": {
    "setup": "deno install && git config core.hooksPath .githooks",
    "test": "deno test tests/",
    "lint": "deno lint",
    "check": "deno check src/bookings.ts src/contact-name.ts src/dates.ts src/invoices.ts src/orders.ts src/products.ts",
    "docs": "deno run --allow-run --allow-read --allow-write scripts/generate-api-docs.ts",
    "docs:check": "deno task docs && git diff --exit-code -- API.md API.json"
  },
  "imports": {
    "date-fns": "npm:date-fns@^4.1.0",
    "@date-fns/tz": "npm:@date-fns/tz@^1.4.1",
    "currency.js": "npm:currency.js@^2.0.4",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@cfs/schemas": "jsr:@cfs/schemas@7.0.0-beta.49"
  },
  "compilerOptions": {
    "strict": true
  },
  "publish": {
    "include": [
      "src/",
      "deno.json",
      "LICENSE",
      "README.md",
      "API.md",
      "API.json"
    ]
  }
}
