{
  "branches": [
    "main",
    { "name": "beta", "prerelease": "beta" },
    { "name": "pre-*", "prerelease": "beta", "channel": "beta" },
    { "name": "beta-*", "prerelease": "beta", "channel": "beta" }
  ],
  "plugins": [
    ["@semantic-release/commit-analyzer", { "preset": "conventionalcommits" }],
    ["@semantic-release/release-notes-generator", { "preset": "conventionalcommits" }],
    ["@semantic-release/exec", {
      "prepareCmd": "deno eval \"const c = JSON.parse(Deno.readTextFileSync('deno.json')); c.version = '${nextRelease.version}'; Deno.writeTextFileSync('deno.json', JSON.stringify(c, null, 2) + '\\n');\"",
      "publishCmd": "deno publish --allow-dirty"
    }],
    ["@semantic-release/git", {
      "assets": ["deno.json"],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    "@semantic-release/github"
  ]
}
